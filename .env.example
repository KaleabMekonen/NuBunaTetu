# ── NuBunaTetu Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.

# Anthropic Claude API (for script generation) — get at console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API (for DALL-E 3 illustrated image generation) — get at platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot (for video delivery to your phone)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
