# ── NuBunaTetu Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.

# Google Gemini API — FREE, 1500 requests/day. Get key at: aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot (for video delivery to your phone) — optional
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Images are generated free via Pollinations.ai — no key needed!
